# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

.env

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.tanstack/*

# i18n sync transient reports — regenerated by `bun run i18n:sync`,
# the canonical state lives in src/i18n/locales/<lang>.json.
src/i18n/locales/_reports/*.untranslated.json

# Source folders named data must remain trackable even though the repo root
# ignores runtime data directories.
!src/**/data/
!src/**/data/**
